<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:sfb="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             x:Class="Athena.UI.ToSAcceptView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Text="{loc:Translate ToSChangedTitle}"
           Margin="5,20,5,2"
           FontAttributes="Bold"
           LineBreakMode="WordWrap"
           VerticalTextAlignment="Center"
           Grid.ColumnSpan="2"
           HorizontalTextAlignment="Center"
           FontSize="32"/>

        <Label Text="{loc:Translate ToSChangedDescription}"
           Grid.Row="1"
           LineBreakMode="WordWrap"
           VerticalTextAlignment="Center"
           HorizontalTextAlignment="Center"
           Grid.Column="0"
           Margin="5"/>

        <sfb:SfButton Style="{x:StaticResource ListButton}"
                  Margin="10, 10, 5, 10"
                  Grid.Row="2"
                  Clicked="OnPrivacyPolicyClicked"
                  Text="{loc:Translate SettingsPrivacyPolicyTitle}"/>

        <sfb:SfButton Style="{x:StaticResource ListButton}"
                  Margin="10, 10, 5, 10"
                  Grid.Row="3"
                  Clicked="OnTermsOfUseClicked"
                  Text="{loc:Translate SettingsTermsOfUseTitle}"/>

        <Grid Grid.Row="4"
              Grid.Column="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <sfb:SfCheckBox Grid.Column="0"
                    IsChecked="{Binding IsConfirmChecked}"
                    
                    Margin="10, 20, 10, 20"/>

            <Label Grid.Column="1"
                   Margin="0, 20, 10, 20"
                   Text="{loc:Translate ToSChangedCheckConfirm}"
                   LineBreakMode="WordWrap"/>

        </Grid>
    </Grid>
</ContentView>
